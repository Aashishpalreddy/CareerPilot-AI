# =====================================================
# CareerPilot AI - Complete Git Ignore
# =====================================================


# =========================
# Python
# =========================

# Byte-compiled files
__pycache__/
*.py[codz]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# Python cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/

# Logs
*.log


# =========================
# Backend - FastAPI
# =========================

# Uploaded user files
backend/uploads/

# Generated documents
backend/generated_documents/
backend/generated_resumes/

# Local database files
*.sqlite
*.sqlite3
*.db

# Migration cache
backend/migrations/__pycache__/


# =========================
# AI / ML Generated Files
# =========================

# Model files
*.pt
*.pth
*.bin
*.onnx

# Temporary AI outputs
outputs/
results/


# =========================
# Frontend - Next.js
# =========================

# Node dependencies
node_modules/

frontend/node_modules/

# Next.js build
.next/
frontend/.next/

# Production build
out/

# Environment variables
frontend/.env
frontend/.env.local
frontend/.env.production


# =========================
# React / TypeScript
# =========================

*.tsbuildinfo


# =========================
# IDE / Editors
# =========================

.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db


# =========================
# Temporary Files
# =========================

tempCodeRunnerFile.py
*.tmp
*.temp
*.swp


# =========================
# Coverage / Testing
# =========================

.coverage
coverage.xml
htmlcov/


# =========================
# Jupyter
# =========================

.ipynb_checkpoints/


